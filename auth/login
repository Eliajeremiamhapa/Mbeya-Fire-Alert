<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | GEMS TFRF Mbeya</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.9)), 
                        url('https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?auto=format&fit=crop&q=80');
            background-size: cover;
            background-position: center;
        }
        .glass {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="h-screen flex items-center justify-center p-4">

    <div class="glass w-full max-w-md p-8 rounded-3xl shadow-2xl">
        <!-- Logo Area -->
        <div class="text-center mb-8">
            <div class="bg-red-600 w-20 h-20 rounded-2xl mx-auto mb-4 flex items-center justify-center shadow-lg transform -rotate-12">
                <span class="text-white text-3xl font-black italic">TFRF</span>
            </div>
            <h1 class="text-white text-2xl font-black uppercase tracking-tighter">GEMS Command Login</h1>
            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mt-1">Mbeya Region Operations</p>
        </div>

        <!-- Login Form -->
        <form id="loginForm" class="space-y-5">
            <div>
                <label class="block text-[10px] font-black text-red-500 uppercase mb-1 ml-1">Email / Username</label>
                <input type="text" name="email" required
                    class="w-full bg-white/10 border border-white/20 p-4 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-red-500 transition-all font-bold"
                    placeholder="mfano@tfrf.go.tz">
            </div>

            <div>
                <label class="block text-[10px] font-black text-red-500 uppercase mb-1 ml-1">Password</label>
                <input type="password" name="password" required
                    class="w-full bg-white/10 border border-white/20 p-4 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-red-500 transition-all font-bold"
                    placeholder="••••••••">
            </div>

            <button type="submit" 
                class="w-full bg-red-600 hover:bg-red-700 text-white py-4 rounded-xl font-black uppercase tracking-widest shadow-xl shadow-red-900/20 transform active:scale-95 transition-all">
                Ingia kwenye Mfumo
            </button>
        </form>

            <!-- Error Message Display -->
            <div id="errorMessage" class="hidden mt-4 p-3 bg-red-500/20 border border-red-500/50 rounded-lg text-red-200 text-xs text-center font-bold italic">
            </div>

        <!-- Footer Note -->
        <div class="mt-8 pt-6 border-t border-white/10 text-center">
            <p class="text-slate-500 text-[10px] font-bold uppercase">Authorized Personnel Only</p>
            <a href="/" class="text-red-500 text-[10px] font-black uppercase mt-2 block hover:underline">← Rudi kwenye SOS</a>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').onsubmit = async (e) => {
            e.preventDefault();
            const errorBox = document.getElementById('errorMessage');
            errorBox.classList.add('hidden');

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                // Tunatuma data kwenda kwenye auth route ya server
                const response = await fetch('/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    // Kama login imefanikiwa, mfumo unampeleka mtu kulingana na Role yake
                    window.location.href = result.redirectUrl;
                } else {
                    // Kama imefeli, onyesha ujumbe wa kosa
                    errorBox.textContent = result.message || "Umeingiza taarifa zisizo sahihi!";
                    errorBox.classList.remove('hidden');
                }
            } catch (err) {
                errorBox.textContent = "Hitilafu imetokea. Jaribu tena baadae.";
                errorBox.classList.remove('hidden');
            }
        };
    </script>
</body>
</html>